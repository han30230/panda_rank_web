# 배포 시 실제 도메인으로 설정하면 OG·사이트맵·canonical URL이 맞춰집니다.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# SQLite (로컬 기본: 프로젝트 루트 dev.db)
DATABASE_URL="file:./dev.db"

# 실시간 트렌드(콘텐츠 스튜디오) — 비우면 Google 뉴스 한국 RSS 기본 URL 사용
# TRENDING_RSS_URL=https://news.google.com/rss?hl=ko&gl=KR&ceid=KR:ko

# 키워드 분석·블로그 초안 생성 — 없으면 서버 휴리스틱만 사용
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# 대시보드·결제 화면의 크레딧·플랜 표시 (선택)
# MONTHLY_CREDIT_CAP=5000
# CREDITS_PER_REPORT=80
# BILLING_PLAN_LABEL=프로

# 비밀번호 찾기 — true면 API 응답에 재설정 경로를 포함(로컬 개발용, 운영에서는 끄세요)
# PASSWORD_RESET_DEV_LINK=true
